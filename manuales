  </div>
</div>

<!-- ═══ Modal: Ver ═══ -->
<div class="overlay" id="viewOverlay">
  <div class="modal">
    <div class="modal-head">
      <h2>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        <span id="vTitle" style="max-width:360px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"></span>
      </h2>
      <button class="modal-close" onclick="closeOverlay('viewOverlay')">✕</button>
    </div>
    <div class="view-row">
      <div class="view-lbl">Área</div>
      <div style="display:inline-block">
        <span class="card-tag" id="vTag" style="font-size:12px;padding:4px 12px"></span>
      </div>
    </div>
    <div class="view-row">
      <div class="view-lbl">Descripción</div>
      <div class="view-val" id="vDesc"></div>
    </div>
    <div class="view-row" id="vUrlRow">
      <div class="view-lbl">Acceder</div>
      <a class="view-link" id="vUrl" href="#" target="_blank" rel="noopener">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Abrir manual
      </a>
    </div>
    <div class="view-row">
      <div class="view-lbl">Fecha de carga</div>
      <div style="font-size:12px;color:rgba(0,180,210,0.5);font-family:'Courier New',monospace" id="vDate"></div>
    </div>
    <div class="modal-foot">
      <button class="btn-cancel" onclick="closeOverlay('viewOverlay')">Cerrar</button>
    </div>
  </div>
</div>

<script>
/* ── Background canvas ── */
const cv = document.getElementById('bgc'), ctx = cv.getContext('2d');
function drawBg() {
  cv.width = window.innerWidth; cv.height = window.innerHeight;
  const W = cv.width, H = cv.height;
  ctx.clearRect(0,0,W,H);
  for(let x=0;x<W;x+=36){ctx.beginPath();ctx.moveTo(x,0);ctx.lineTo(x,H);ctx.strokeStyle='rgba(0,160,220,0.05)';ctx.lineWidth=.5;ctx.stroke();}
  for(let y=0;y<H;y+=36){ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.strokeStyle='rgba(0,160,220,0.05)';ctx.stroke();}
  for(let x=0;x<W;x+=36) for(let y=0;y<H;y+=36){
    ctx.beginPath();ctx.arc(x,y,.9,0,Math.PI*2);
    ctx.fillStyle=Math.random()>.72?'rgba(0,230,255,0.28)':'rgba(255,255,255,0.06)';ctx.fill();
  }
  for(let i=0;i<80;i++){
    const x=Math.random()*W,y=Math.random()*H,r=Math.random()*1.1+.15;
    ctx.beginPath();ctx.arc(x,y,r,0,Math.PI*2);
    ctx.fillStyle=Math.random()>.5?`rgba(0,220,255,${Math.random()*.3+.04})`:`rgba(255,255,255,${Math.random()*.15+.02})`;ctx.fill();
  }
  const br=22;[[22,22,1,1],[W-22,22,-1,1],[22,H-22,1,-1],[W-22,H-22,-1,-1]].forEach(([bx,by,sx,sy])=>{
    ctx.beginPath();ctx.moveTo(bx,by+sy*br);ctx.lineTo(bx,by);ctx.lineTo(bx+sx*br,by);
    ctx.strokeStyle='rgba(0,230,255,0.3)';ctx.lineWidth=1.2;ctx.stroke();
  });
}
drawBg(); window.addEventListener('resize', drawBg);

/* ── Data ── */
let items = JSON.parse(localStorage.getItem('adminhub_manuales') || '[]');
let editId = null;

function persist() { localStorage.setItem('adminhub_manuales', JSON.stringify(items)); }

function iconFor(tag) {
  const t = (tag||'').toLowerCase();
  if(t.includes('rrhh')||t.includes('personas')) return '👥';
  if(t.includes('it')||t.includes('tech')||t.includes('sistem')) return '💻';
  if(t.includes('oper')) return '⚙️';
  if(t.includes('finanz')||t.includes('contab')||t.includes('admin')) return '💰';
  if(t.includes('segur')) return '🔒';
  if(t.includes('legal')||t.includes('jurí')) return '📋';
  if(t.includes('calid')) return '✅';
  if(t.includes('comerc')||t.includes('venta')) return '📈';
  if(t.includes('cobro')) return '💳';
  return '📄';
}

function esc(s){ return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

/* ── Render ── */
function filterList() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const filtered = items.filter(m =>
    m.title.toLowerCase().includes(q) ||
    (m.desc||'').toLowerCase().includes(q) ||
    (m.tag||'').toLowerCase().includes(q)
  );
  render(filtered);
}

function render(data) {
  const grid = document.getElementById('grid');
  const pill = document.getElementById('countPill');
  pill.textContent = data.length + ' manual' + (data.length !== 1 ? 'es' : '');

  if (!data.length) {
    grid.innerHTML = `
      <div class="empty-state" style="grid-column:1/-1">
        <svg width="48" height="48" viewBox="0 0 30 30" fill="none">
          <rect x="4" y="2" width="22" height="26" rx="3" stroke="#22D3EE" stroke-width="1.5"/>
          <path d="M9 10h12M9 15h12M9 20h8" stroke="#22D3EE" stroke-width="1.3" stroke-linecap="round"/>
        </svg>
        <p>${items.length ? 'Ningún manual coincide con la búsqueda' : 'No hay manuales cargados todavía'}</p>
        <p class="sub">${items.length ? 'Probá con otro término' : 'Hacé clic en "Nuevo manual" para comenzar'}</p>
      </div>`;
    return;
  }

  grid.innerHTML = data.map((m, i) => {
    const realIdx = items.indexOf(m);
    return `<div class="m-card" style="animation-delay:${i * 0.05}s">
      <div class="card-top">
        <div class="card-icon">${iconFor(m.tag)}</div>
        <div class="card-title-block">
          <div class="card-title">${esc(m.title)}</div>
          ${m.tag ? `<span class="card-tag">${esc(m.tag)}</span>` : ''}
        </div>
      </div>
      ${m.desc ? `<div class="card-desc">${esc(m.desc.substring(0,100))}${m.desc.length>100?'…':''}</div>` : ''}
      <div class="card-footer">
        <span class="card-date">${m.date || ''}</span>
        <div class="card-actions">
          <button class="icon-btn" onclick="viewItem(${realIdx})" title="Ver">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </button>
          <button class="icon-btn" onclick="openEdit(${realIdx})" title="Editar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="icon-btn danger" onclick="deleteItem(${realIdx})" title="Eliminar">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
          </button>
        </div>
      </div>
    </div>`;
  }).join('');
}

/* ── CRUD ── */
function openAdd() {
  editId = null;
  document.getElementById('formTitle').textContent = 'Nuevo manual';
  ['fTitle','fDesc','fUrl','fTag'].forEach(id => document.getElementById(id).value = '');
  openOverlay('formOverlay');
}

function openEdit(idx) {
  const m = items[idx]; if (!m) return;
  editId = idx;
  document.getElementById('formTitle').textContent = 'Editar manual';
  document.getElementById('fTitle').value = m.title;
  document.getElementById('fDesc').value  = m.desc || '';
  document.getElementById('fUrl').value   = m.url  || '';
  document.getElementById('fTag').value   = m.tag  || '';
  openOverlay('formOverlay');
}

function saveManual() {
  const title = document.getElementById('fTitle').value.trim();
  if (!title) { alert('El título es obligatorio.'); return; }
  const obj = {
    title,
    desc : document.getElementById('fDesc').value.trim(),
    url  : document.getElementById('fUrl').value.trim(),
    tag  : document.getElementById('fTag').value.trim(),
    date : editId !== null ? items[editId].date : new Date().toLocaleDateString('es-AR')
  };
  if (editId !== null) items[editId] = obj;
  else items.unshift(obj);
  persist();
  closeOverlay('formOverlay');
  filterList();
}

function viewItem(idx) {
  const m = items[idx]; if (!m) return;
  document.getElementById('vTitle').textContent = m.title;
  document.getElementById('vTag').textContent   = m.tag || 'Sin etiqueta';
  document.getElementById('vDesc').textContent  = m.desc || 'Sin descripción.';
  document.getElementById('vDate').textContent  = m.date || '—';
  const linkEl = document.getElementById('vUrl');
  const linkRow = document.getElementById('vUrlRow');
  if (m.url) { linkEl.href = m.url; linkRow.style.display = 'block'; }
  else { linkRow.style.display = 'none'; }
  openOverlay('viewOverlay');
}

function deleteItem(idx) {
  if (!confirm(`¿Eliminar "${items[idx]?.title}"?`)) return;
  items.splice(idx, 1);
  persist(); filterList();
}

/* ── Overlay helpers ── */
function openOverlay(id)  { document.getElementById(id).classList.add('open'); }
function closeOverlay(id) { document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(o =>
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); })
);

/* ── Init ── */
filterList();
</script>
</body>
</html>
