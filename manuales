<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Manuales — Admin Hub</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: #020B18;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #E0F7FF;
  min-height: 100vh;
}

/* ── Background layers ── */
.bg-overlay {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background: radial-gradient(ellipse at center, rgba(0,10,25,0.55) 0%, rgba(2,11,24,0.88) 70%, rgba(2,11,24,0.97) 100%);
}
canvas#bgc { position: fixed; inset: 0; z-index: 1; pointer-events: none; }

/* ── Topbar ── */
.topbar {
  position: relative; z-index: 20;
  padding: 22px 28px 18px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid rgba(0,230,255,0.08);
}
.brand { display: flex; align-items: center; gap: 12px; }
.brand-sq {
  width: 40px; height: 40px; border-radius: 11px;
  background: #003A5C; border: 1px solid rgba(0,230,255,0.4);
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.brand-name { color: #fff; font-size: 17px; font-weight: 500; letter-spacing: -0.02em; }
.brand-dept { color: rgba(0,230,255,0.38); font-size: 11px; margin-top: 2px; letter-spacing: 0.03em; }

.back-btn {
  display: flex; align-items: center; gap: 7px;
  background: rgba(0,90,130,0.15);
  border: 1px solid rgba(0,230,255,0.25);
  border-radius: 10px; padding: 7px 14px;
  color: rgba(0,230,255,0.8); font-size: 12px; letter-spacing: 0.03em;
  cursor: pointer; text-decoration: none;
  transition: all 0.2s;
}
.back-btn:hover { background: rgba(0,230,255,0.1); border-color: rgba(0,230,255,0.6); color: #00E6FF; }

/* ── Page header ── */
.page-head {
  position: relative; z-index: 10;
  padding: 28px 32px 0;
  display: flex; align-items: flex-end; justify-content: space-between; flex-wrap: wrap; gap: 16px;
}
.page-title-block {}
.page-eyebrow {
  font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
  color: rgba(0,230,255,0.35); margin-bottom: 6px;
  display: flex; align-items: center; gap: 6px;
}
.page-eyebrow::before {
  content: ''; display: inline-block;
  width: 18px; height: 1px; background: rgba(0,230,255,0.3);
}
.page-title {
  font-size: 26px; font-weight: 600; letter-spacing: -0.03em; color: #E0F7FF;
  display: flex; align-items: center; gap: 12px;
}
.page-title svg { filter: drop-shadow(0 0 8px rgba(0,230,255,0.5)); }
.page-sub { color: rgba(0,200,230,0.35); font-size: 12px; margin-top: 5px; }

.add-btn {
  display: flex; align-items: center; gap: 8px;
  background: rgba(0,80,130,0.3);
  border: 1.5px solid rgba(0,230,255,0.4);
  border-radius: 10px; padding: 10px 18px;
  color: #00E6FF; font-size: 13px; font-weight: 500;
  cursor: pointer; transition: all 0.2s; white-space: nowrap;
  font-family: inherit;
}
.add-btn:hover { background: rgba(0,230,255,0.12); border-color: #00E6FF; transform: translateY(-1px); }

/* ── Toolbar ── */
.toolbar {
  position: relative; z-index: 10;
  padding: 20px 32px 0;
  display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
}
.search-wrap { flex: 1; min-width: 220px; position: relative; }
.search-wrap svg {
  position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
  pointer-events: none; color: rgba(0,230,255,0.3);
}
.search-input {
  width: 100%;
  background: rgba(0,20,40,0.8);
  border: 1px solid rgba(0,230,255,0.18);
  border-radius: 10px; padding: 10px 14px 10px 38px;
  color: #E0F7FF; font-size: 13px; font-family: inherit;
  outline: none; transition: border-color 0.2s;
}
.search-input:focus { border-color: rgba(0,230,255,0.5); box-shadow: 0 0 0 3px rgba(0,230,255,0.07); }
.search-input::placeholder { color: rgba(0,200,230,0.22); }

.count-pill {
  background: rgba(0,30,55,0.8);
  border: 1px solid rgba(0,230,255,0.15);
  border-radius: 8px; padding: 6px 12px;
  font-size: 11px; color: rgba(0,200,230,0.5);
  letter-spacing: 0.05em; white-space: nowrap;
}

/* ── Divider ── */
.divider {
  position: relative; z-index: 10;
  margin: 18px 32px 0;
  height: 1px; background: rgba(0,230,255,0.07);
}

/* ── Grid ── */
.grid {
  position: relative; z-index: 10;
  padding: 20px 32px 40px;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 14px;
}

/* ── Manual card ── */
.m-card {
  background: rgba(0,18,38,0.85);
  border: 1px solid rgba(0,230,255,0.12);
  border-radius: 14px; padding: 18px;
  display: flex; flex-direction: column; gap: 12px;
  transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  cursor: default;
  position: relative; overflow: hidden;
}
.m-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, rgba(0,230,255,0.25), transparent);
  opacity: 0; transition: opacity 0.2s;
}
.m-card:hover {
  border-color: rgba(0,230,255,0.35);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(0,80,180,0.15);
}
.m-card:hover::before { opacity: 1; }

.card-top { display: flex; align-items: flex-start; gap: 12px; }
.card-icon {
  width: 42px; height: 42px; flex-shrink: 0;
  border-radius: 10px;
  background: rgba(0,40,70,0.9);
  border: 1px solid rgba(0,230,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
}
.card-title-block { flex: 1; min-width: 0; }
.card-title {
  font-size: 14px; font-weight: 600; color: #E0F7FF;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  line-height: 1.3;
}
.card-tag {
  display: inline-block; margin-top: 4px;
  font-size: 10px; padding: 2px 8px; border-radius: 999px;
  background: rgba(0,230,255,0.08);
  border: 1px solid rgba(0,230,255,0.2);
  color: rgba(0,230,255,0.6); letter-spacing: 0.04em;
}

.card-desc {
  font-size: 12px; color: rgba(0,200,230,0.4);
  line-height: 1.6; flex: 1;
}

.card-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 10px;
  border-top: 1px solid rgba(0,230,255,0.07);
}
.card-date { font-size: 10px; color: rgba(0,180,210,0.3); font-family: 'Courier New', monospace; letter-spacing: 0.05em; }
.card-actions { display: flex; gap: 6px; }

.icon-btn {
  width: 30px; height: 30px;
  border-radius: 7px;
  background: transparent;
  border: 1px solid rgba(0,230,255,0.15);
  color: rgba(0,210,255,0.5);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.15s; font-size: 13px;
}
.icon-btn:hover { background: rgba(0,230,255,0.1); border-color: rgba(0,230,255,0.5); color: #00E6FF; }
.icon-btn.danger:hover { background: rgba(163,45,45,0.2); border-color: rgba(240,149,149,0.4); color: #F09595; }

/* ── Empty state ── */
.empty-state {
  position: relative; z-index: 10;
  text-align: center; padding: 5rem 2rem;
  color: rgba(0,200,230,0.3);
}
.empty-state svg { margin-bottom: 16px; opacity: 0.4; }
.empty-state p { font-size: 14px; }
.empty-state .sub { font-size: 12px; margin-top: 6px; color: rgba(0,180,210,0.2); }

/* ── Scan animation on load ── */
@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.m-card { animation: fadeSlideUp 0.4s ease both; }

/* ── Modals ── */
.overlay {
  position: fixed; inset: 0; z-index: 200;
  background: rgba(0,5,15,0.85); backdrop-filter: blur(6px);
  display: none; align-items: center; justify-content: center; padding: 1rem;
}
.overlay.open { display: flex; }

.modal {
  width: min(520px, 96vw);
  max-height: 90vh; overflow-y: auto;
  background: #030E1E;
  border: 1px solid rgba(0,230,255,0.3);
  border-radius: 18px; padding: 24px;
  box-shadow: 0 0 60px rgba(0,180,255,0.12), 0 0 120px rgba(0,80,180,0.06);
  animation: fadeSlideUp 0.3s ease;
}
.modal-head {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 20px;
  padding-bottom: 14px;
  border-bottom: 1px solid rgba(0,230,255,0.1);
}
.modal-head h2 { font-size: 15px; font-weight: 600; color: #E0F7FF; display: flex; align-items: center; gap: 8px; }
.modal-close {
  width: 30px; height: 30px; border-radius: 8px;
  background: transparent; border: 1px solid rgba(0,230,255,0.2);
  color: rgba(0,230,255,0.5); font-size: 15px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  transition: all 0.15s;
}
.modal-close:hover { background: rgba(0,230,255,0.1); color: #00E6FF; border-color: rgba(0,230,255,0.5); }

.field { margin-bottom: 14px; }
.field label {
  display: block; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
  color: rgba(0,200,230,0.4); margin-bottom: 6px;
}
.field input, .field textarea, .field select {
  width: 100%;
  background: rgba(0,20,40,0.8);
  border: 1px solid rgba(0,230,255,0.18);
  border-radius: 9px; padding: 10px 13px;
  color: #E0F7FF; font-size: 13px; font-family: inherit;
  outline: none; transition: border-color 0.2s;
}
.field input:focus, .field textarea:focus {
  border-color: rgba(0,230,255,0.5);
  box-shadow: 0 0 0 3px rgba(0,230,255,0.07);
}
.field input::placeholder, .field textarea::placeholder { color: rgba(0,200,230,0.22); }
.field textarea { resize: vertical; min-height: 80px; }

.modal-foot {
  display: flex; justify-content: flex-end; gap: 8px;
  padding-top: 14px; border-top: 1px solid rgba(0,230,255,0.08); margin-top: 4px;
}
.btn-cancel {
  background: transparent; border: 1px solid rgba(0,230,255,0.2);
  border-radius: 9px; padding: 9px 16px;
  color: rgba(0,200,230,0.5); font-size: 13px; cursor: pointer;
  font-family: inherit; transition: all 0.15s;
}
.btn-cancel:hover { background: rgba(0,230,255,0.06); color: #00E6FF; }
.btn-save {
  background: rgba(0,80,130,0.4); border: 1.5px solid rgba(0,230,255,0.45);
  border-radius: 9px; padding: 9px 20px;
  color: #00E6FF; font-size: 13px; font-weight: 500; cursor: pointer;
  font-family: inherit; transition: all 0.15s;
}
.btn-save:hover { background: rgba(0,230,255,0.12); border-color: #00E6FF; }
.btn-save:disabled { opacity: 0.4; cursor: not-allowed; }

/* View modal */
.view-row { margin-bottom: 14px; }
.view-lbl {
  font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase;
  color: rgba(0,200,230,0.3); margin-bottom: 5px;
}
.view-val {
  font-size: 13px; color: rgba(220,245,255,0.75); line-height: 1.6;
  background: rgba(0,20,40,0.6); border: 1px solid rgba(0,230,255,0.1);
  border-radius: 8px; padding: 10px 13px;
  white-space: pre-wrap; max-height: 180px; overflow-y: auto;
}
.view-link {
  display: inline-flex; align-items: center; gap: 7px;
  color: #00E6FF; font-size: 13px; text-decoration: none;
  background: rgba(0,80,130,0.25); border: 1px solid rgba(0,230,255,0.25);
  border-radius: 8px; padding: 8px 14px;
  transition: all 0.15s;
}
.view-link:hover { background: rgba(0,230,255,0.1); border-color: rgba(0,230,255,0.5); }

/* Scan line on cards */
@keyframes scan-line {
  0% { top: -2px; } 100% { top: 102%; }
}

/* corner decorations */
.corner-tl, .corner-tr, .corner-bl, .corner-br {
  position: fixed; width: 30px; height: 30px;
  z-index: 5; pointer-events: none;
}
.corner-tl { top: 14px; left: 14px; border-top: 1.5px solid rgba(0,230,255,0.35); border-left: 1.5px solid rgba(0,230,255,0.35); }
.corner-tr { top: 14px; right: 14px; border-top: 1.5px solid rgba(0,230,255,0.35); border-right: 1.5px solid rgba(0,230,255,0.35); }
.corner-bl { bottom: 14px; left: 14px; border-bottom: 1.5px solid rgba(0,230,255,0.35); border-left: 1.5px solid rgba(0,230,255,0.35); }
.corner-br { bottom: 14px; right: 14px; border-bottom: 1.5px solid rgba(0,230,255,0.35); border-right: 1.5px solid rgba(0,230,255,0.35); }

.sys-tag {
  position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
  font-family: 'Courier New', monospace; font-size: 9px; letter-spacing: 0.14em;
  color: rgba(0,200,255,0.15); z-index: 5; pointer-events: none;
}

@media (max-width: 600px) {
  .topbar, .page-head, .toolbar, .divider, .grid { padding-left: 16px; padding-right: 16px; }
  .grid { grid-template-columns: 1fr; }
  .page-title { font-size: 20px; }
}
</style>
</head>
<body>

<div class="bg-overlay"></div>
<canvas id="bgc"></canvas>

<!-- Corner decorations -->
<div class="corner-tl"></div>
<div class="corner-tr"></div>
<div class="corner-bl"></div>
<div class="corner-br"></div>
<div class="sys-tag">SYS.DOCS v1.0 · NET.ACTIVE</div>

<!-- Topbar -->
<div class="topbar">
  <div class="brand">
    <div class="brand-sq">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
        <rect x="2" y="2" width="7" height="7" rx="1.5" fill="#00E6FF"/>
        <rect x="11" y="2" width="7" height="7" rx="1.5" fill="#00E6FF"/>
        <rect x="2" y="11" width="7" height="7" rx="1.5" fill="#00E6FF"/>
        <rect x="11" y="11" width="7" height="7" rx="1.5" fill="rgba(0,230,255,0.28)"/>
      </svg>
    </div>
    <div>
      <div class="brand-name">Admin Hub</div>
      <div class="brand-dept">Gestión Cobros</div>
    </div>
  </div>
  <a href="../index.html" class="back-btn">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
    Volver al Hub
  </a>
</div>

<!-- Page header -->
<div class="page-head">
  <div class="page-title-block">
    <div class="page-eyebrow">módulo · documentación</div>
    <div class="page-title">
      <svg width="26" height="26" viewBox="0 0 30 30" fill="none">
        <rect x="4" y="2" width="22" height="26" rx="3" stroke="#22D3EE" stroke-width="1.7"/>
        <path d="M9 10h12M9 15h12M9 20h8" stroke="#22D3EE" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      Manuales
    </div>
    <div class="page-sub">Documentación operativa · Gestión de Cobros</div>
  </div>
  <button class="add-btn" onclick="openAdd()">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    Nuevo manual
  </button>
</div>

<!-- Toolbar -->
<div class="toolbar">
  <div class="search-wrap">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    <input class="search-input" id="searchInput" type="text" placeholder="Buscar por título, área o descripción…" oninput="filterList()">
  </div>
  <div class="count-pill" id="countPill">— manuales</div>
</div>

<div class="divider"></div>

<!-- Grid -->
<div class="grid" id="grid"></div>

<!-- ═══ Modal: Agregar / Editar ═══ -->
<div class="overlay" id="formOverlay">
  <div class="modal">
    <div class="modal-head">
      <h2>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#22D3EE" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
        <span id="formTitle">Nuevo manual</span>
      </h2>
      <button class="modal-close" onclick="closeOverlay('formOverlay')">✕</button>
    </div>
    <div class="field">
      <label>Título *</label>
      <input type="text" id="fTitle" placeholder="Nombre del manual">
    </div>
    <div class="field">
      <label>Descripción</label>
      <textarea id="fDesc" placeholder="Breve descripción del contenido…"></textarea>
    </div>
    <div class="field">
      <label>Enlace al archivo</label>
      <input type="url" id="fUrl" placeholder="https://…">
    </div>
    <div class="field">
      <label>Área / Etiqueta</label>
      <input type="text" id="fTag" placeholder="Ej: RRHH, Operaciones, IT…">
    </div>
    <div class="modal-foot">
